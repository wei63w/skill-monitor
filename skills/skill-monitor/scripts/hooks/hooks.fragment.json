{
  "version": 1,
  "hooks": {
    "beforeReadFile": [
      {
        "command": "node .cursor/hooks/skill-monitor-on-read.mjs"
      }
    ],
    "subagentStart": [
      {
        "command": "node .cursor/hooks/skill-monitor-on-subagent.mjs"
      }
    ],
    "preToolUse": [
      {
        "command": "node .cursor/hooks/skill-monitor-on-subagent.mjs",
        "matcher": "Task"
      }
    ]
  }
}
